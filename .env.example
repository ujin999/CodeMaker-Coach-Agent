# CodeMaker Coach Agent — 환경변수 예시
# 실제 값은 .env 에 넣고, .env 는 커밋하지 않는다.

# ── LLM Provider ──────────────────────────────────
LLM_PROVIDER=openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ── Embeddings / Vector Store (RAG) ───────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Database (PostgreSQL) ─────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codemaker

# ── 인증 (JWT) ─────────────────────────────────────
# 반드시 안전한 랜덤 값으로 채운다. 비워두면 서버가 기동을 거부한다 (NFR-3).
# 생성 예: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=60

# ── Judge0 (채점) ─────────────────────────────────
JUDGE0_URL=http://localhost:2358
JUDGE0_AUTH_TOKEN=

# ── Graph RAG (Neo4j, 확장/선택) ──────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── App ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000


# CodeMaker Coach Agent — 환경변수 예시
# 실제 값은 .env 에 넣고, .env 는 커밋하지 않는다.

# ── LLM Provider ──────────────────────────────────
LLM_PROVIDER=openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ── Embeddings / Vector Store (RAG) ───────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Database (PostgreSQL) ─────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codemaker

# ── 인증 (JWT) ─────────────────────────────────────
# 반드시 안전한 랜덤 값으로 채운다. 비워두면 서버가 기동을 거부한다 (NFR-3).
# 생성 예: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=60

# ── Judge0 (채점) ─────────────────────────────────
JUDGE0_URL=http://localhost:2358
JUDGE0_AUTH_TOKEN=

# ── Graph RAG (Neo4j, 확장/선택) ──────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── App ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=10000
# 프론트엔드 배포 주소(콤마 구분) — 브라우저에서 이 origin의 요청만 API가 허용한다.
# 서버에 배포할 때는 반드시 실제 접속 주소(예: http://<서버IP>:10001)를 추가할 것.
CORS_ORIGINS=http://localhost:10001,http://127.0.0.1:10001

# ── Web (Next.js, apps/web) ───────────────────────────
# 브라우저가 직접 호출하는 백엔드 주소. 빌드 시점에 번들에 박히라 배포 주소로 설정.
NEXT_PUBLIC_API_BASE_URL=http://localhost:10000

# CodeMaker Coach Agent — 환경변수 예시
# 실제 값은 .env 에 넣고, .env 는 커밋하지 않는다.

# ── LLM Provider ──────────────────────────────────
# claude | openai (LangChain이 이 값으로 ChatModel을 선택)
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Embeddings / Vector Store (RAG) ───────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
EMBEDDING_MODEL=

# ── Database (PostgreSQL) ─────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codemaker

# ── Judge0 (채점) ─────────────────────────────────
JUDGE0_URL=http://localhost:2358
JUDGE0_AUTH_TOKEN=

# ── Graph RAG (Neo4j, 확장/선택) ──────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── App ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# 채점 큐: MVP는 인메모리(별도 설정 불필요). 확장 시 아래로 전환
# QUEUE_BACKEND=memory   # memory | redis
# REDIS_URL=redis://localhost:6379/0
